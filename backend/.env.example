# ── Core (required) ───────────────────────────────────────────────────────────
PORT=8000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/unbindai?retryWrites=true&w=majority
JWT_SECRET=generate-with-python-c-import-secrets-print-secrets-token_hex-32
GROQ_API_KEY=gsk_your-groq-api-key-here
FRONTEND_URL=http://localhost:3000

# ── HyDE (optional) ───────────────────────────────────────────────────────────
# Separate Groq key used ONLY for HyDE (hypothetical document generation during
# retrieval). Using a distinct key means HyDE calls draw on their own per-key
# rate limit instead of sharing GROQ_API_KEY's quota. Falls back to GROQ_API_KEY
# if left unset.
HYDE_KEY=gsk_your-hyde-groq-api-key-here

# Separate Groq key used ONLY for the negotiation copilot (drafting negotiation
# messages). Same idea as HYDE_KEY — its own per-key rate limit so drafting
# doesn't eat into the main analysis quota. Falls back to GROQ_API_KEY if unset.
NEGOTIATION_KEY=gsk_your-negotiation-groq-api-key-here

# ── Google OAuth (required for "Sign in with Google") ─────────────────────────
GOOGLE_CLIENT_ID=get-this-from-google-developer-console
GOOGLE_CLIENT_SECRET=get-this-from-google-developer-console

# ── Razorpay (required for paid plans on /pricing) ────────────────────────────
# Get keys from https://dashboard.razorpay.com/app/keys. Use TEST keys
# (rzp_test_…) for development — no real money moves; pay with test cards/UPI
# (e.g. card 4111 1111 1111 1111, any future expiry/CVV; UPI success@razorpay).
# Swap for LIVE keys (rzp_live_…) in production. KEY_ID is public; KEY_SECRET
# is private and must stay server-side.
RAZORPAY_KEY_ID=rzp_test_your-key-id-here
RAZORPAY_KEY_SECRET=your-razorpay-key-secret-here
# Webhook secret (Razorpay Dashboard → Settings → Webhooks). Point the webhook
# at POST {BACKEND_URL}/api/user/plan/webhook and subscribe to the
# "payment.captured" event. This is the reliable server-to-server confirmation
# that grants the plan even if the browser never returns to call /verify.
# Leave empty to disable the webhook endpoint (it returns 503 when unset).
RAZORPAY_WEBHOOK_SECRET=

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=generate-from-langsmith-dashboard
LANGSMITH_PROJECT="unbind"

# Embeddings run on HuggingFace's hosted Inference API (free). Get a token at
# https://huggingface.co/settings/tokens (a read token is enough).
HUGGINGFACEHUB_API_TOKEN=hf_xxxxxxxxxxxxxxxx

# ── Email / SMTP (required for lawyer-contact emails) ─────────────────────────
# SMTP_USER / SMTP_PASSWORD must be set for outbound email to work; if empty,
# email sending is skipped with a warning. For Gmail, SMTP_PASSWORD is an
# App Password (https://support.google.com/accounts/answer/185833), not your login.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME=UnBind AI

# ── Auth / cookie tunables (optional — sane defaults shown) ───────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
COOKIE_NAME=unbind_token

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Opt-in regex to also allow Vercel preview deployments, e.g.
# VERCEL_PREVIEW_REGEX=https://myproject-.*\.vercel\.app
# Left unset by default so only FRONTEND_URL (and localhost) are allowed.
VERCEL_PREVIEW_REGEX=
