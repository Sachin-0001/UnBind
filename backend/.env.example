# ── Core (required) ───────────────────────────────────────────────────────────
PORT=8000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/unbindai?retryWrites=true&w=majority
JWT_SECRET=generate-with-python-c-import-secrets-print-secrets-token_hex-32
GROQ_API_KEY=gsk_your-groq-api-key-here
FRONTEND_URL=http://localhost:3000

# ── Google OAuth (required for "Sign in with Google") ─────────────────────────
GOOGLE_CLIENT_ID=get-this-from-google-developer-console
GOOGLE_CLIENT_SECRET=get-this-from-google-developer-console

# ── LangSmith tracing (optional) ──────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=generate-from-langsmith-dashboard
LANGSMITH_PROJECT="unbind"

# Embeddings run on HuggingFace's hosted Inference API (free). Get a token at
# https://huggingface.co/settings/tokens (a read token is enough).
HUGGINGFACEHUB_API_TOKEN=hf_xxxxxxxxxxxxxxxx

# ── Email / SMTP (required for lawyer-contact emails) ─────────────────────────
# SMTP_USER / SMTP_PASSWORD must be set for outbound email to work; if empty,
# email sending is skipped with a warning. For Gmail, SMTP_PASSWORD is an
# App Password (https://support.google.com/accounts/answer/185833), not your login.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME=UnBind AI

# ── Auth / cookie tunables (optional — sane defaults shown) ───────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
COOKIE_NAME=unbind_token

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Opt-in regex to also allow Vercel preview deployments, e.g.
# VERCEL_PREVIEW_REGEX=https://myproject-.*\.vercel\.app
# Left unset by default so only FRONTEND_URL (and localhost) are allowed.
VERCEL_PREVIEW_REGEX=
